# Server
PORT=8080
APP_ENV=development
SERVER_READ_TIMEOUT=15s
SERVER_WRITE_TIMEOUT=15s
SERVER_IDLE_TIMEOUT=60s

# Database
DB_HOST=localhost
DB_PORT=5432
DB_USER=postgres
DB_PASSWORD=postgres
DB_NAME=condo_manager
DB_SSLMODE=disable

# Session
SESSION_SECRET=your-very-secret-key-change-in-production
SESSION_MAX_AGE=604800

# CORS
ALLOWED_ORIGINS=http://localhost:8080

# File Upload
UPLOAD_DIR=app/uploads
MAX_UPLOAD_SIZE=10485760

# AI (optional)
AI_API_KEY=
AI_MODEL=gpt-4o
AI_TIMEOUT=30s
